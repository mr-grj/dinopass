# Config for docker-compose.prod.yml. Copy to ".env" next to it and edit.
#   cp .env.prod.example .env

# Required
# A strong database password. Generate one with: openssl rand -base64 32
POSTGRES_PASSWORD=change-me

# Image version
# "latest", or pin to a release tag like v0.3.0 for reproducible deploys.
DINOPASS_VERSION=latest

# URL the BROWSER uses to reach the API (your host + backend port + /api):
DINOPASS_API_URL=http://localhost:8000/api

# Origin the BROWSER loads the UI from (your host + frontend port):
DINOPASS_FRONTEND_ORIGIN=http://localhost:3000

# Optional
# POSTGRES_USER=dinopass
# POSTGRES_DB=dinopass
# DINOPASS_FRONTEND_PORT=3000
# DINOPASS_BACKEND_PORT=8000
