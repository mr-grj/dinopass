# Config for docker-compose.prod.yml. Copy to ".env" next to it and edit.
#   cp .env.prod.example .env

# Required
# A strong database password. Generate one with: openssl rand -base64 32
POSTGRES_PASSWORD=change-me

# Image version
# "latest", or pin to a release like 1.2.0 (no leading "v") for reproducible deploys.
CIPHERMOTH_VERSION=latest

# URL the BROWSER uses to reach the API (your host + backend port + /api):
CIPHERMOTH_API_URL=http://localhost:8000/api

# Origin the BROWSER loads the UI from (your host + frontend port):
CIPHERMOTH_FRONTEND_ORIGIN=http://localhost:3000

# Optional
# POSTGRES_USER=ciphermoth
# POSTGRES_DB=ciphermoth
# CIPHERMOTH_FRONTEND_PORT=3000
# CIPHERMOTH_BACKEND_PORT=8000

# One-click updates (opt-in)
# The in-app "Update" button needs a helper container that holds the Docker
# socket. It's OFF by default. To enable it, start the stack with:
#   make prod-up-autoupdate      (or: docker compose -f docker-compose.prod.yml --profile autoupdate up -d)
# The updater cosign-verifies every image against the official release workflow
# before applying, snapshots the DB, and auto-rolls-back on failure. Without it,
# the app still notifies you of updates and shows the manual command to run.
